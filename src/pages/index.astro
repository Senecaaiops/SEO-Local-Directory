---
import directoryData from '../../seo_directory_data.json';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google Analytics Integration Fix - PLACED FIRST FOR GOOGLEBOT SCANNER -->
    <script async src="https://googletagmanager.com"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1V2WX4K30H');
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Georgia Regional B2B Trade Directory Network</title>
    <!-- Full CSS and Body content available in source -->
    <style>
        :root { --primary: #0f172a; --accent: #2563eb; --accent-hover: #1d4ed8; --text-main: #334155; --text-dark: #0f172a; --bg-main: #f8fafc; --bg-card: #ffffff; --border: #e2e8f0; }
        body { font-family: system-ui, -apple-system, sans-serif; line-height: 1.5; max-width: 1040px; margin: 0 auto; padding: 40px 24px; color: var(--text-main); background: var(--bg-main); }
        header { text-align: center; margin-bottom: 50px; padding-bottom: 30px; border-bottom: 1px solid var(--border); }
        h1 { color: var(--text-dark); font-size: 2.5rem; font-weight: 800; margin: 0 0 12px 0; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(310px, 1fr)); gap: 24px; }
        .card { background: var(--bg-card); border: 1px solid var(--border); padding: 24px; border-radius: 12px; }
        .btn { display: inline-block; background: var(--accent); color: #fff; text-decoration: none; padding: 12px 20px; border-radius: 8px; font-weight: 600; }
    </style>
</head>
<body>
    <header><h1>Georgia Trade Network</h1></header>
    <div class="grid">
        {directoryData.map((page) => (
            <div class="card">
                <h3>{page.trade}</h3>
                <a href={`/${page.url_slug}`} class="btn">Browse Contractors →</a>
            </div>
        ))}
    </div>
</body>
</html>
