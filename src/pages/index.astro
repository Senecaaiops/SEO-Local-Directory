---
import directoryData from '../../seo_directory_data.json';
---
<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://googletagmanager.com"></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-1V2WX4K30H');
    </script>

    <meta name="google-site-verification" content="0pm49ZI_MprlamJXqzlGsN_5-9JZXg39Lyazw9RXJGY" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Georgia Regional B2B Trade Directory Network</title>
    <style>
        :root {
            --primary: #0f172a;
            --accent: #2563eb;
            --accent-hover: #1d4ed8;
            --text-main: #334155;
            --text-dark: #0f172a;
            --bg-main: #f8fafc;
            --bg-card: #ffffff;
            --border: #e2e8f0;
        }
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.5;
            max-width: 1040px;
            margin: 0 auto;
            padding: 40px 24px;
            color: var(--text-main);
            background: var(--bg-main);
        }
        header {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 30px;
            border-bottom: 1px solid var(--border);
        }
        h1 {
            color: var(--text-dark);
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -0.025em;
            margin: 0 0 12px 0;
        }
        .subtitle {
            color: var(--text-main);
            font-size: 1.15rem;
            max-width: 700px;
            margin: 0 auto;
        }
        .search-container {
            max-width: 500px;
            margin: 0 auto 40px auto;
            text-align: center;
        }
        .search-input {
            width: 100%;
            padding: 14px 20px;
            font-size: 1rem;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: var(--bg-card);
            color: var(--text-dark);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .search-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        }
        .section-block.is-hidden {
            display: none;
        }
        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-dark);
            margin: 40px 0 20px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
            gap: 24px;
        }
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            padding: 24px;
            border-radius: 12px;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card.is-hidden {
            display: none !important;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        }
        .card h3 {
            margin: 0 0 12px 0;
            color: var(--text-dark);
            font-size: 1.35rem;
            font-weight: 700;
        }
        .card p {
            margin: 0 0 20px 0;
            color: var(--text-main);
            font-size: 0.95rem;
        }
        .tag {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 600;
            padding: 4px 8px;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
        }
        .tag-commercial {
            background: #eff6ff;
            color: #1e40af;
        }
        .tag-residential {
            background: #fdf2f8;
            color: #9d174d;
        }
        .btn {
            display: inline-block;
            background: var(--accent);
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 600;
            text-align: center;
            font-size: 0.95rem;
        }
        .btn:hover {
            background: var(--accent-hover);
        }
        .no-results {
            display: none;
            text-align: center;
            padding: 40px;
            background: var(--bg-card);
            border: 1px dashed var(--border);
            border-radius: 12px;
            color: var(--text-main);
            font-size: 1.1rem;
        }
        .no-results.is-visible {
            display: block;
        }
    </style>
</head>
<body>
    <header>
        <h1>Georgia Trade Network</h1>
        <p class="subtitle">The trusted procurement hub for localized asset management, commercial facility contractors, and vetted residential subdivision field crews.</p>
    </header>

    <!-- Interactive Search Bar -->
    <div class="search-container">
        <input type="text" id="directorySearch" class="search-input" placeholder="Search trades (e.g., Roofing, HVAC, Plumbing)..." aria-label="Search directory categories" />
    </div>

    <!-- Empty State Informational Banner -->
    <div id="emptyState" class="no-results">
        🔍 No matching service trades found. Try searching for another keyword.
    </div>
    <div class="section-block" id="commercialSection">
        <h2 class="section-title">🏢 Commercial Logistics & Industrial Asset Zones</h2>
        <div class="grid" style="margin-bottom: 50px;">
            {(() => {
                const uniqueCommercialTrades = directoryData
                    .filter(p => p.type === "Commercial")
                    .filter((value, index, self) => 
                        self.findIndex(t => t.trade === value.trade) === index
                    );

                return uniqueCommercialTrades.map((page) => {
                    const allMatchingRecords = directoryData.filter(p => p.type === "Commercial" && p.trade === page.trade);
                    const totalCount = allMatchingRecords.reduce((sum, current) => sum + (current.listings ? current.listings.length : 0), 0);
                    const totalVetted = allMatchingRecords.reduce((sum, current) => sum + (current.listings ? current.listings.filter(l => l.vetted).length : 0), 0);
                    const cleanMasterSlug = page.trade.toLowerCase().replace(/\s+/g, '-');

                    return (
                        <div class="card" data-search-name={page.trade.toLowerCase()}>
                            <div>
                                <span class="tag tag-commercial">Commercial</span>
                                <h3>{page.trade} Services</h3>
                                <p>Connecting asset managers with certified field professionals across all regional industrial parks.</p>
                                
                                <div style="margin: 12px 0; padding: 10px; background: var(--bg-main); border-radius: 8px; font-size: 0.85rem;">
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                                        <span>📋 Total Contractors:</span>
                                        <strong>{totalCount} Teams Available</strong>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; color: #16a34a;">
                                        <span>🛡️ Vetted Providers:</span>
                                        <strong>{totalVetted} Verified Across Network</strong>
                                    </div>
                                </div>
                            </div>
                            <a href={`/commercial/${cleanMasterSlug}`} class="btn" data-trade={page.trade} data-type="Commercial">
                                Browse Vetted Contractors →
                            </a>
                        </div>
                    )
                });
            })()}
        </div>
    </div>

    <div class="section-block" id="residentialSection">
        <h2 class="section-title">🏡 Premium Subdivisions & Neighborhood Clusters</h2>
        <div class="grid">
            {(() => {
                const uniqueResidentialTrades = directoryData
                    .filter(p => p.type === "Residential")
                    .filter((value, index, self) => 
                        self.findIndex(t => t.trade === value.trade) === index
                    );

                return uniqueResidentialTrades.map((page) => {
                    const allMatchingRecords = directoryData.filter(p => p.type === "Residential" && p.trade === page.trade);
                    const totalCount = allMatchingRecords.reduce((sum, current) => sum + (current.listings ? current.listings.length : 0), 0);
                    const totalVetted = allMatchingRecords.reduce((sum, current) => sum + (current.listings ? current.listings.filter(l => l.vetted).length : 0), 0);
                    const cleanMasterSlug = page.trade.toLowerCase().replace(/\s+/g, '-');

                    return (
                        <div class="card" data-search-name={page.trade.toLowerCase()}>
                            <div>
                                <span class="tag tag-residential">Residential</span>
                                <h3>{page.trade} Services</h3>
                                <p>Connecting residential property owners and HOA managers with local certified crews.</p>
                                
                                <div style="margin: 12px 0; padding: 10px; background: var(--bg-main); border-radius: 8px; font-size: 0.85rem;">
                                    <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                                        <span>📋 Total Contractors:</span>
                                        <strong>{totalCount} Teams Available</strong>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; color: #9d174d;">
                                        <span>🛡️ Vetted Providers:</span>
                                        <strong>{totalVetted} Verified Across Network</strong>
                                    </div>
                                </div>
                            </div>
                            <a href={`/residential/${cleanMasterSlug}`} class="btn" data-trade={page.trade} data-type="Residential">
                                Browse Vetted Contractors →
                            </a>
                        </div>
                    )
                });
            })()}
        </div>
    </div>

    <script is:inline>
        // 1. Client-Side Search Logic
        const searchInput = document.getElementById('directorySearch');
        const cards = document.querySelectorAll('.card');
        const commercialSection = document.getElementById('commercialSection');
        const residentialSection = document.getElementById('residentialSection');
        const emptyState = document.getElementById('emptyState');

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();
            let visibleCommercialCount = 0;
            let visibleResidentialCount = 0;

            cards.forEach(card => {
                const tradeName = card.getAttribute('data-search-name') || '';
                const isCommercial = card.querySelector('.tag').classList.contains('tag-commercial');

                if (tradeName.includes(query)) {
                    card.classList.remove('is-hidden');
                    if (isCommercial) visibleCommercialCount++;
                    else visibleResidentialCount++;
                } else {
                    card.classList.add('is-hidden');
                }
            });

            // Hide/Show section parent headings dynamically
            if (visibleCommercialCount === 0) commercialSection.classList.add('is-hidden');
            else commercialSection.classList.remove('is-hidden');

            if (visibleResidentialCount === 0) residentialSection.classList.add('is-hidden');
            else residentialSection.classList.remove('is-hidden');

            // Handle total empty slate state visibility
            if (visibleCommercialCount === 0 && visibleResidentialCount === 0) {
                emptyState.classList.add('is-visible');
            } else {
                emptyState.classList.remove('is-visible');
            }
        });

        // 2. Click Logging Automation
        document.addEventListener('click', (event) => {
            const button = event.target.closest('.btn');
            if (!button) return;

            const trade = button.getAttribute('data-trade');
            const sectorType = button.getAttribute('data-type');
            const destinationUrl = button.getAttribute('href');

            if (typeof window.gtag === 'function') {
                window.gtag('event', 'directory_click', {
                    'event_category': 'Outbound Navigation',
                    'event_label': trade + ' Master Link',
                    'sector_type': sectorType,
                    'trade_name': trade,
                    'destination_url': destinationUrl
                });
            }
        });
    </script>
</body>
</html>
