---
import directoryData from '../../seo_directory_data.json';
---
<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1V2WX4K30H"></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-1V2WX4K30H');
    </script>

    <meta name="google-site-verification" content="0pm49ZI_MprlamJXqzlGsN_5-9JZXg39Lyazw9RXJGY" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Georgia Regional B2B Trade Directory Network</title>
    <style>
        :root {
            --primary: #0f172a;
            --accent: #2563eb;
            --accent-hover: #1d4ed8;
            --text-main: #334155;
            --text-dark: #0f172a;
            --bg-main: #f8fafc;
            --bg-card: #ffffff;
            --border: #e2e8f0;
        }
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.5;
            max-width: 1040px;
            margin: 0 auto;
            padding: 40px 24px;
            color: var(--text-main);
            background: var(--bg-main);
        }
        header {
            text-align: center;
            margin-bottom: 50px;
            padding-bottom: 30px;
            border-bottom: 1px solid var(--border);
        }
        h1 {
            color: var(--text-dark);
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -0.025em;
            margin: 0 0 12px 0;
        }
        .subtitle {
            color: var(--text-main);
            font-size: 1.15rem;
            max-width: 700px;
            margin: 0 auto;
        }
        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-dark);
            margin: 40px 0 20px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
            gap: 24px;
        }
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            padding: 24px;
            border-radius: 12px;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        }
        .card h3 {
            margin: 0 0 12px 0;
            color: var(--text-dark);
            font-size: 1.35rem;
            font-weight: 700;
        }
        .card p {
            margin: 0 0 20px 0;
            color: var(--text-main);
            font-size: 0.95rem;
        }
        .tag {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 600;
            padding: 4px 8px;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
        }
        .tag-commercial {
            background: #eff6ff;
            color: #1e40af;
        }
        .tag-residential {
            background: #fdf2f8;
            color: #9d174d;
        }
        .btn {
            display: inline-block;
            background: var(--accent);
            color: #fff;
            text-decoration: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 600;
            text-align: center;
            font-size: 0.95rem;
        }
        .btn:hover {
            background: var(--accent-hover);
        }
    </style>
</head>
<body>
    <header>
        <h1>Georgia Trade Network</h1>
        <p class="subtitle">The trusted procurement hub for localized asset management, commercial facility contractors, and vetted residential subdivision field crews.</p>
    </header>

    <!-- Replace your Commercial loop with this upgrade -->
{directoryData.filter(p => p.type === "Commercial").map((page) => {
    // Math logic to calculate average sector metrics inside Astro
    const count = page.listings ? page.listings.length : 0;
    const vettedCount = page.listings ? page.listings.filter(l => l.vetted).length : 0;
    
    return (
        <div class="card">
            <div>
                <span class="tag tag-commercial">Commercial</span>
                <h3>{page.trade}</h3>
                <p>Serving asset managers and facility operators throughout the high-density corridor around <strong>{page.zone}</strong>.</p>
                
                <!-- NEW UI METRICS PANEL -->
                <div style="margin: 12px 0; padding: 10px; background: var(--bg-main); border-radius: 8px; font-size: 0.85rem;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                        <span>📋 Total Contractors:</span>
                        <strong>{count} Teams</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; color: #16a34a;">
                        <span>🛡️ Vetted Providers:</span>
                        <strong>{vettedCount} Verified</strong>
                    </div>
                </div>
            </div>
            <a href={`/${page.url_slug}`} class="btn" data-trade={page.trade} data-zone={page.zone} data-type="Commercial">
                Browse Vetted Contractors →
            </a>
        </div>
    )
})}
<!-- Replace your Residential loop with this matching upgrade -->
{directoryData.filter(p => p.type === "Residential").map((page) => {
    const count = page.listings ? page.listings.length : 0;
    const vettedCount = page.listings ? page.listings.filter(l => l.vetted).length : 0;
    
    return (
        <div class="card">
            <div>
                <span class="tag tag-residential">Residential</span>
                <h3>{page.trade}</h3>
                <p>Connecting residential property owners and neighborhood association managers with certified crews in <strong>{page.zone}</strong>.</p>
                
                <!-- MATCHING RESIDENTIAL METRICS BADGE -->
                <div style="margin: 12px 0; padding: 10px; background: var(--bg-main); border-radius: 8px; font-size: 0.85rem;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                        <span>📋 Active Field Crews:</span>
                        <strong>{count} Companies</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; color: #9d174d;">
                        <span>🛡️ Vetted Providers:</span>
                        <strong>{vettedCount} Verified</strong>
                    </div>
                </div>
            </div>
            <a href={`/${page.url_slug}`} class="btn" data-trade={page.trade} data-zone={page.zone} data-type="Residential">
                Browse Vetted Contractors →
            </a>
        </div>
    )
})}


    <!-- Script handles dynamic outbound link click capturing safely inside Astro -->
    <script is:inline>
        document.addEventListener('click', (event) => {
            const button = event.target.closest('.btn');
            if (!button) return;

            const trade = button.getAttribute('data-trade');
            const zone = button.getAttribute('data-zone');
            const sectorType = button.getAttribute('data-type');
            const destinationUrl = button.getAttribute('href');

            if (typeof window.gtag === 'function') {
                window.gtag('event', 'directory_click', {
                    'event_category': 'Outbound Navigation',
                    'event_label': trade + ' - ' + zone,
                    'sector_type': sectorType,
                    'trade_name': trade,
                    'target_zone': zone,
                    'destination_url': destinationUrl
                });
            }
        });
    </script>
</body>
</html>
