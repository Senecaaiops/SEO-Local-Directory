---
import directoryData from '../../seo_directory_data.json';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google Analytics Integration Fix - PLACED ABSOLUTE FIRST FOR GOOGLEBOT SCANNER -->
    <script async src="https://googletagmanager.com"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1V2WX4K30H');
    </script>

<meta name="google-site-verification" content="0pm49ZI_MprlamJXqzlGsN_5-9JZXg39Lyazw9RXJGY" />

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Georgia Regional B2B Trade Directory Network</title>
    <style>
        :root {
            --primary: #0f172a;
            --accent: #2563eb;
            --accent-hover: #1d4ed8;
            --text-main: #334155;
            --text-dark: #0f172a;
            --bg-main: #f8fafc;
            --bg-card: #ffffff;
            --border: #e2e8f0;
        }
        body { 
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; 
            line-height: 1.5; 
            max-width: 1040px; 
            margin: 0 auto; 
            padding: 40px 24px; 
            color: var(--text-main); 
            background: var(--bg-main); 
        }
        header {
            text-align: center;
            margin-bottom: 50px;
            padding-bottom: 30px;
            border-bottom: 1px solid var(--border);
        }
        h1 { 
            color: var(--text-dark); 
            font-size: 2.5rem; 
            font-weight: 800;
            letter-spacing: -0.025em;
            margin: 0 0 12px 0; 
        }
        .subtitle { 
            color: var(--text-main); 
            font-size: 1.15rem; 
            max-width: 700px;
            margin: 0 auto;
        }
        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-dark);
            margin: 40px 0 20px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(310px, 1fr)); 
            gap: 24px; 
        }
        .card { 
            background: var(--bg-card); 
            border: 1px solid var(--border); 
            padding: 24px; 
            border-radius: 12px; 
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
            display: flex; 
            flex-direction: column; 
            justify-content: space-between; 
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        }
        .card h3 { 
            margin: 0 0 12px 0; 
            color: var(--text-dark); 
            font-size: 1.35rem; 
            font-weight: 700;
        }
        .card p { 
            margin: 0 0 20px 0; 
            color: var(--text-main); 
            font-size: 0.95rem; 
        }
        .tag {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 600;
            padding: 4px 8px;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
        }
        .tag-commercial { background: #eff6ff; color: #1e40af; }
        .tag-residential { background: #fdf2f8; color: #9d174d; }
        .btn { 
            display: inline-block; 
            background: var(--accent); 
            color: #fff; 
            text-decoration: none; 
            padding: 12px 20px; 
            border-radius: 8px; 
            font-weight: 600; 
            text-align: center; 
            font-size: 0.95rem; 
        }
        .btn:hover { background: var(--accent-hover); }
    </style>
</head>
<body>
    <header>
        <h1>Georgia Trade Network</h1>
        <p class="subtitle">The trusted procurement hub for localized asset management, commercial facility contractors, and vetted residential subdivision field crews.</p>
    </header>

    <h2 class="section-title">🏢 Commercial Logistics & Industrial Asset Zones</h2>
    <div class="grid" style="margin-bottom: 50px;">
        {directoryData.filter(p => p.type === "Commercial").map((page) => (
            <div class="card">
                <div>
                    <span class="tag tag-commercial">Commercial</span>
                    <h3>{page.trade}</h3>
                    <p>Serving asset managers and facility operators throughout the high-density corridor around <strong>{page.zone}</strong>.</p>
                </div>
                <a href={`/${page.url_slug}`} class="btn">Browse Vetted Contractors →</a>
            </div>
        ))}
    </div>

    <h2 class="section-title">🏡 Premium Subdivisions & Neighborhood Clusters</h2>
    <div class="grid">
        {directoryData.filter(p => p.type === "Residential").map((page) => (
            <div class="card">
                <div>
                    <span class="tag tag-residential">Residential</span>
                    <h3>{page.trade}</h3>
                    <p>Connecting residential property owners and neighborhood association managers with certified crews in <strong>{page.zone}</strong>.</p>
                </div>
                <a href={`/${page.url_slug}`} class="btn">Browse Vetted Contractors →</a>
            </div>
        ))}
    </div>
</body>
</html>
