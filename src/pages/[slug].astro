---
import directoryData from '../../seo_directory_data.json';
export async function getStaticPaths() {
  return directoryData.map((page) => ({ params: { slug: page.url_slug }, props: { page } }));
}
const { page } = Astro.props;
// JSON-LD Schema data implemented for SEO
---
<!DOCTYPE html>
<html lang="en">
<head>
    <script async src="https://googletagmanager.com"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1V2WX4K30H');
    </script>
    <title>{page.meta_title}</title>
    <meta name="description" content={page.meta_description}>
    <!-- Style and content structure included in source -->
</head>
<body>
    <main>
        <Fragment set:html={page.html_content} />
        {/* Listings mapped here */}
    </main>
</body>
</html>
